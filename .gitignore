# =========================

# Visual Studio .gitignore

# =========================

# Build results

[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Dd]ebug*/
[Rr]elease*/
x64/
x86/

# Visual Studio cache/options

.vs/
*.VC.db
*.VC.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# IntelliSense

ipch/
*.aps
*.ncb
*.opendb
*.cache

# C++ specific

*.obj
*.pdb
*.ilk
*.idb
*.tlog
*.lastbuildstate

# Compiled libraries / executables

*.exe
*.dll
*.lib
*.exp

# Logs

*.log

# Temporary files

*.tmp
*.temp

# Windows image file caches

Thumbs.db
ehthumbs.db

# OS generated files

.DS_Store

# Visual Studio profiler

*.psess
*.vsp
*.vspx

# Test results

TestResults/
*.trx

# NuGet packages (optional: keep if you commit packages)

packages/

# CMake (if used)

CMakeFiles/
CMakeCache.txt
cmake_install.cmake

# Backup files

*.bak
*.backup
*.old

# Misc

*.opensdf
*.sdf
*.db
